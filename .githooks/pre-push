#!/bin/bash
# Pre-push hook — run lint on new/modified code before pushing.
# Compares against origin/main to catch only new issues.
#
# Install: git config core.hooksPath .githooks

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
SERVER_DIR="$ROOT_DIR/server"
WEB_DIR="$SERVER_DIR/web"

# Get the remote tracking branch, or fall back to origin/main
REMOTE_BRANCH="origin/main"
# In a pre-push hook, Git passes refs on stdin — try to extract the remote branch
if [ -t 0 ]; then
    : # no stdin (manual invocation)
else
    while read -r _local_ref _local_sha _remote_ref _remote_sha; do
        REMOTE_BRANCH="${_remote_ref#refs/remotes/}"
        break
    done
fi

# Compare commits being pushed against the remote branch
MERGE_BASE=$(git merge-base "$REMOTE_BRANCH" HEAD 2>/dev/null || echo "HEAD~10")
CHANGED_GO=$(git diff --name-only --diff-filter=ACMR "$MERGE_BASE" HEAD -- 'server/**/*.go' 2>/dev/null || true)
CHANGED_TS=$(git diff --name-only --diff-filter=ACMR "$MERGE_BASE" HEAD -- 'server/web/**/*.ts' 'server/web/**/*.tsx' 2>/dev/null || true)

# Trim whitespace
CHANGED_GO=$(echo "$CHANGED_GO" | sed '/^$/d')
CHANGED_TS=$(echo "$CHANGED_TS" | sed '/^$/d')

if [ -z "$CHANGED_GO" ] && [ -z "$CHANGED_TS" ]; then
    exit 0
fi

echo "🔍 Running pre-push lint checks..."
echo "   → comparing against $REMOTE_BRANCH (merge-base $MERGE_BASE)"

HAS_ERRORS=0

# --- Go lint ---
if [ -n "$CHANGED_GO" ]; then
    GO_FILES=$(echo "$CHANGED_GO" | sed "s|^server/||")
    cd "$SERVER_DIR"

    # gofmt
    UNFORMATTED=$(gofmt -l $GO_FILES)
    if [ -n "$UNFORMATTED" ]; then
        echo "  ✖ gofmt errors — run 'gofmt -w' on:" >&2
        echo "$UNFORMATTED" >&2
        HAS_ERRORS=1
    fi

    # golangci-lint — warn if missing, don't block
    if command -v golangci-lint &>/dev/null; then
        echo "  → golangci-lint ($(echo "$CHANGED_GO" | wc -l | tr -d ' ') files)..."
        if ! golangci-lint run ./... >&2; then
            echo "  ✖ Go lint errors found. Fix them before pushing." >&2
            HAS_ERRORS=1
        fi
    else
        echo "  ⚠ golangci-lint not found, skipping Go lint. Install: brew install golangci-lint" >&2
    fi
fi

# --- Frontend lint ---
if [ -n "$CHANGED_TS" ]; then
    OXLINT=""
    if command -v oxlint &>/dev/null; then
        OXLINT="oxlint"
    elif [ -x "$WEB_DIR/node_modules/.bin/oxlint" ]; then
        OXLINT="$WEB_DIR/node_modules/.bin/oxlint"
    fi

    if [ -n "$OXLINT" ]; then
        cd "$WEB_DIR"
        # Strip server/web/ prefix so paths are relative to $WEB_DIR
        TS_FILES=$(echo "$CHANGED_TS" | sed "s|^server/web/||")
        echo "  → oxlint ($(echo "$TS_FILES" | wc -l | tr -d ' ') files)..."
        if echo "$TS_FILES" | grep -q .; then
            if ! $OXLINT --deny-warnings $TS_FILES >&2; then
                echo "  ✖ Frontend lint errors found. Fix them before pushing." >&2
                HAS_ERRORS=1
            fi
        fi
    else
        echo "  ⚠ oxlint not found, skipping frontend lint. Install: cd server/web && npm install" >&2
    fi
fi

if [ "$HAS_ERRORS" -ne 0 ]; then
    echo "❌ Pre-push checks failed. Push aborted." >&2
    exit 1
fi

echo "✅ Pre-push lint checks passed."
